# Copy this file to .env.local (which is gitignored) and fill in real values.
# The app reads these at runtime via BrightpearlConfig.from_env() /
# SftpConfig.from_env() etc. Never commit .env.local.

# --- Brightpearl --------------------------------------------------------------
# Account code: the WBYS subdomain in your Brightpearl URL.
#   e.g. https://eu1.brightpearlapp.com/wbys/  ->  wbys
BRIGHTPEARL_ACCOUNT_CODE=

# Datacenter: the subdomain in your Brightpearl API URL.
#   Common values: use1, eu1, ws-eu1, ws-use1
BRIGHTPEARL_DATACENTER=

# App reference: the reference assigned when the app was registered with
# Brightpearl (e.g. wbys_ops_engine).
BRIGHTPEARL_APP_REF=

# Account token: the secret token that authenticates API calls on behalf of
# the Brightpearl app. Treat this like a password.
BRIGHTPEARL_ACCOUNT_TOKEN=

# --- Gardiner Brothers SFTP ---------------------------------------------------
# The WBYS-owned SFTP server that Gardiners read/write files through.
GBR_SFTP_HOST=ec2-63-32-88-8.eu-west-1.compute.amazonaws.com
GBR_SFTP_PORT=22
GBR_SFTP_USERNAME=
GBR_SFTP_PASSWORD=

# --- Gardiner Brothers JIT integration config --------------------------------
# Brightpearl contact ID of the Gardiner Bros & Co (B1358) supplier account.
# NOT the B3116 DF dropship account.
GBR_JIT_SUPPLIER_CONTACT_ID=

# Brightpearl ID of the "Cost Price GBR (Net)" price list. The Gardiners SKU
# for each product is resolved from that price list's SKU field.
GBR_JIT_PRICE_LIST_ID=

# Brightpearl custom-status IDs. Look these up once; then pin here.
GBR_JIT_STATUS_ID_REQUEST_SENT=
GBR_JIT_STATUS_ID_PENDING=

# SFTP folders agreed with Gardiners (subject to confirmation with Sam).
GBR_JIT_ORDERS_PATH=/JIT/Orders/
GBR_JIT_NOTIFICATIONS_PATH=/JIT/Notifications/

# Optional: override the outbound filename template. Placeholders:
#   {order_reference}  -- the PO's reference (or ID if no reference is set)
#   {timestamp}        -- UTC yyyymmddHHMM at upload time
# GBR_JIT_FILE_NAME_TEMPLATE={order_reference}-{timestamp}.csv
